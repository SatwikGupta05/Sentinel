{
  "name": "sentinel",
  "version": "1.0.0",
  "private": true,
  "description": "🛡️ Supply Chain Security Guardian - Catch malicious npm packages before they destroy your project",
  "bin": {
    "sentinel": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "cli": "tsx src/cli/index.ts",
    "db:init": "tsx src/db/init.ts",
    "generate-key": "tsx src/api/generate-key.ts",
    
    "setup": "npm run db:init && echo '✅ Database initialized. Run: npm run dev'"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "sql.js": "^1.11.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
