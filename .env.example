# 🛡️  Sentinel - Environment Configuration
# Copy this to .env and fill in your values

# === Database ===
# Choose: sqlite (dev) or supabase (production)
DB_TYPE=sqlite
# SQLite only: path to database file
DB_PATH=./data/sentinel.db

# Supabase only (for production):
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key_here

# === AI Analysis ===
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === API Auth ===
# Generate a key: npm run generate-key
SENTINEL_API_KEY=sk_sentinel_your_key_here

# === GitHub Integration ===
# For GitHub Action - needs repo:read scope
# GITHUB_TOKEN=ghp_your_token_here

# === Server ===
PORT=5000
NODE_ENV=development

# === Rate Limiting (optional overrides) ===
# RATE_LIMIT_RPM=30
# RATE_LIMIT_RPD=1000
# MAX_PACKAGES_PER_SCAN=50

# === Logging ===
# LOG_LEVEL=info
